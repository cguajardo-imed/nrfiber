# New Relic Configuration
# Get your license key from: https://one.newrelic.com/launcher/api-keys-ui.api-keys-launcher
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key-here

# Server Configuration
PORT=3000

# Application Name (optional - defaults are set in code)
# APP_NAME=my-fiber-app

# New Relic Additional Settings (optional)
# NEW_RELIC_APP_NAME=my-custom-app-name
# NEW_RELIC_LOG_LEVEL=info

# Development/Production Environment
# ENV=development
